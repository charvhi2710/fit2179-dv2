{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "How the ranking flips",
    "subtitle": "The same states, in two different orders.",
    "anchor": "start",
    "offset": 12,
    "fontSize": 17,
    "font": "Open Sans",
    "fontWeight": 700,
    "subtitleFontSize": 13,
    "subtitleFont": "Open Sans",
    "subtitleColor": "#666",
    "subtitlePadding": 4
  },
  "width": "container",
  "height": 480,
  "padding": {"left": 0, "right": 12, "top": 8, "bottom": 8},
  "autosize": {"type": "fit", "contains": "padding"},
  "background": null,
  "data": {"url": "data/analysis_state_2023.json"},
  "transform": [
    {
      "fold": ["rank_by_count", "rank_by_rate"],
      "as": ["metric_field", "rank"]
    },
    {
      "calculate": "datum.metric_field === 'rank_by_count' ? 'By COUNT' : 'By RATE'",
      "as": "metric"
    },
    {
    "calculate": "datum.state + '  ·  #' + datum.rank",
    "as": "label_left"
    },
    {
    "calculate": "'#' + datum.rank + '  ·  ' + datum.state",
    "as": "label_right"
  }
  ],
  "layer": [
    {
      "mark": {
        "type": "line",
        "point": {"filled": true, "size": 70},
        "strokeWidth": 1.5
      },
      "encoding": {
        "x": {
          "field": "metric",
          "type": "ordinal",
          "scale": {"padding": 0.5, "domain": ["By COUNT", "By RATE"]},
          "axis": {
            "orient": "top",
            "title": null,
            "labelFont": "Open Sans",
            "labelFontSize": 14,
            "labelFontWeight": 700,
            "labelColor": "#1a1a1a",
            "labelPadding": 18,
            "labelAngle": 0,
            "domain": false,
            "ticks": false
          }
        },
        "y": {
          "field": "rank",
          "type": "quantitative",
          "scale": {"reverse": true, "domain": [0.5, 14.5]},
          "axis": null
        },
        "color": {
          "condition": [
            {"test": "datum.state === 'Selangor'", "value": "#1e3a5f"},
            {"test": "datum.state === 'Penang'", "value": "#a47e1b"}
          ],
          "value": "#b8b8b8"
        },
        "detail": {"field": "state"},
        "tooltip": [
          {"field": "state", "title": "State"},
          {"field": "metric", "title": "Ranked"},
          {"field": "rank", "title": "Rank"}
        ]
      }
    },
    {
      "transform": [{"filter": "datum.metric === 'By COUNT'"}],
      "mark": {
        "type": "text",
        "align": "right",
        "dx": -12,
        "fontSize": 12,
        "font": "Open Sans"
      },
      "encoding": {
        "x": {"field": "metric", "type": "ordinal"},
        "y": {"field": "rank", "type": "quantitative"},
        "text": {"field": "label_left"},
        "color": {
          "condition": [
            {"test": "datum.state === 'Selangor'", "value": "#1e3a5f"},
            {"test": "datum.state === 'Penang'", "value": "#a47e1b"}
          ],
          "value": "#333"
        }
      }
    },
    {
      "transform": [{"filter": "datum.metric === 'By RATE'"}],
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 12,
        "fontSize": 12,
        "font": "Open Sans"
      },
      "encoding": {
        "x": {"field": "metric", "type": "ordinal"},
        "y": {"field": "rank", "type": "quantitative"},
        "text": {"field": "label_right"},
        "color": {
          "condition": [
            {"test": "datum.state === 'Selangor'", "value": "#1e3a5f"},
            {"test": "datum.state === 'Penang'", "value": "#a47e1b"}
          ],
          "value": "#333"
        }
      }
    }
  ],
  "config": {
    "view": {"stroke": null},
    "font": "Open Sans"
  }
}